# ============================================================================
# Multicloud Curator — Backend Environment Variables
# ============================================================================
# Salin file ini ke `.env` di folder backend/ dan isi nilai real
# ============================================================================

# ----- Google OAuth Client (Google Cloud Console) -----
# Buat OAuth 2.0 Client ID (type: Web application).
# Authorized redirect URI: http://localhost:8000/api/accounts/connect/callback
# Scope diminta saat runtime: https://www.googleapis.com/auth/drive
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/accounts/connect/callback

# ----- Dropbox App (Dropbox App Console) -----
# App type: Scoped access, Full Dropbox.
# Redirect URI: http://localhost:8000/api/accounts/connect/callback
# Scope diminta saat runtime: account_info.read, files.metadata.read,
#   files.content.write, sharing.read, sharing.write
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REDIRECT_URI=http://localhost:8000/api/accounts/connect/callback

# ----- Token Encryption Key -----
# Generate dengan:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Hasilnya base64 ~44 char. Paste ke baris di bawah.
# WAJIB di-set; backend gagal start saat operasi token kalau key kosong atau tidak valid.
# Backup nilai ini — kalau hilang, semua token tersimpan harus di-reauth ulang.
TOKEN_ENCRYPTION_KEY=

# ----- Database -----
# SQLite lokal. Default OK untuk dev.
DATABASE_URL=sqlite:///./app.db

# ----- Server config -----
BACKEND_PORT=8000
FRONTEND_DEV_PORT=5173
# Setelah provider callback ke backend selesai, backend redirect browser ke URL ini.
FRONTEND_REDIRECT_BASE_URL=http://localhost:5173

# ----- Logging -----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ----- CORS (untuk dev) -----
# Frontend dev origin. Produksi: same-origin (frontend served by backend).
CORS_ALLOWED_ORIGINS=http://localhost:5173
